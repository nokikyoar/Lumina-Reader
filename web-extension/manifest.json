{
  "manifest_version": 3,
  "name": "Lumina Reader Bridge",
  "version": "0.3.0",
  "description": "Bridge in-page selection to Lumina Reader host via postMessage.",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}